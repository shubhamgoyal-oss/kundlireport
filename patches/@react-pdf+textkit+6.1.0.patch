diff --git a/node_modules/@react-pdf/textkit/lib/textkit.js b/node_modules/@react-pdf/textkit/lib/textkit.js
index 4e1b193..e079760 100644
--- a/node_modules/@react-pdf/textkit/lib/textkit.js
